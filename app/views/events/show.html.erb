<h1>イベント詳細</h1>

<p>
  タイトル: <%= @event.title %>
</p>

<h2>ログ貼り付け</h2>

<%= form_with url: event_messages_path(@event) do %>
  <%= text_area_tag :log_text %>

  <%= submit_tag "取り込み" %>
<% end %>

<h2>ログ一覧</h2>

<% @event.messages.each do |message| %>
  <div>
    <p><%= message.speaker_name %></p>
    <p><%= message.content %></p>
    <p><%= message.posted_at %></p>
  </div>
<% end %>

<%= link_to "編集", edit_event_path(@event) %>
<%= button_to "削除",
              @event,
              method: :delete,
              form: { data: { turbo_confirm: "本当に削除しますか？" } } %>

<%= link_to "一覧へ戻る", events_path %>