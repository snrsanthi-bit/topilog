<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>TopiLog - イベントの「誰に聞けばいいか」がわかる</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Manrope:wght@600;700;800&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Manrope:wght@100..900&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-secondary-fixed-variant": "#005236",
                        "background": "#f8f9ff",
                        "surface-bright": "#f8f9ff",
                        "on-primary-fixed": "#00174b",
                        "error": "#ba1a1a",
                        "surface-container": "#e5eeff",
                        "on-primary": "#ffffff",
                        "secondary-container": "#6cf8bb",
                        "primary": "#004ac6",
                        "on-tertiary": "#ffffff",
                        "surface-container-highest": "#d3e4fe",
                        "tertiary-fixed": "#ffddb8",
                        "primary-fixed-dim": "#b4c5ff",
                        "on-secondary": "#ffffff",
                        "on-surface-variant": "#434655",
                        "outline": "#737686",
                        "on-tertiary-fixed": "#2a1700",
                        "on-tertiary-container": "#ffeedd",
                        "tertiary-fixed-dim": "#ffb95f",
                        "on-secondary-container": "#00714d",
                        "inverse-surface": "#213145",
                        "on-error": "#ffffff",
                        "surface-container-lowest": "#ffffff",
                        "error-container": "#ffdad6",
                        "on-secondary-fixed": "#002113",
                        "on-error-container": "#93000a",
                        "surface-container-high": "#dce9ff",
                        "secondary-fixed-dim": "#4edea3",
                        "on-surface": "#0b1c30",
                        "on-background": "#0b1c30",
                        "surface-container-low": "#eff4ff",
                        "surface": "#f8f9ff",
                        "surface-tint": "#0053db",
                        "inverse-on-surface": "#eaf1ff",
                        "on-tertiary-fixed-variant": "#653e00",
                        "primary-container": "#2563eb",
                        "tertiary-container": "#996100",
                        "primary-fixed": "#dbe1ff",
                        "secondary": "#006c49",
                        "secondary-fixed": "#6ffbbe",
                        "inverse-primary": "#b4c5ff",
                        "tertiary": "#784b00",
                        "outline-variant": "#c3c6d7",
                        "surface-dim": "#cbdbf5",
                        "on-primary-container": "#eeefff",
                        "surface-variant": "#d3e4fe",
                        "on-primary-fixed-variant": "#003ea8"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "stack-gap": "12px",
                        "card-padding": "20px",
                        "unit": "4px",
                        "margin": "32px",
                        "gutter": "24px"
                    },
                    "fontFamily": {
                        "body-lg": ["Inter"],
                        "headline-md": ["Manrope"],
                        "headline-lg": ["Manrope"],
                        "body-md": ["Inter"],
                        "label-md": ["Inter"],
                        "code-sm": ["monospace"],
                        "body-sm": ["Inter"]
                    },
                    "fontSize": {
                        "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}],
                        "headline-md": ["24px", {"lineHeight": "32px", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                        "headline-lg": ["32px", {"lineHeight": "40px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                        "label-md": ["14px", {"lineHeight": "20px", "fontWeight": "600"}],
                        "code-sm": ["13px", {"lineHeight": "18px", "fontWeight": "400"}],
                        "body-sm": ["14px", {"lineHeight": "20px", "fontWeight": "400"}]
                    }
                },
            },
        }
      </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .step-line::after {
            content: '';
            position: absolute;
            left: 50%;
            top: 2rem;
            bottom: -2rem;
            width: 2px;
            background-color: #c3c6d7;
            transform: translateX(-50%);
        }
        @media (max-width: 768px) {
            .step-line::after { display: none; }
        }
    </style>
  </head>

  <body>
    <!-- Top Navigation -->
<header class="w-full sticky top-0 z-50 bg-surface shadow-sm h-16 flex items-center">
  <nav class="flex justify-between items-center w-full px-gutter max-w-[1440px] mx-auto">

    <%= link_to "TopiLog",
                user_signed_in? ? events_path : root_path,
                class: "font-headline-md text-headline-md font-bold text-primary" %>

    <div class="flex gap-4 items-center">

      <% if user_signed_in? %>

        <%= link_to "イベント一覧",
                    events_path,
                    class: "text-on-surface-variant hover:text-primary" %>

        <%= link_to "イベント作成",
                    new_event_path,
                    class: "text-on-surface-variant hover:text-primary" %>

        <%= button_to "ログアウト",
                      destroy_user_session_path,
                      method: :delete,
                      class: "px-5 py-2 rounded-lg border border-primary text-primary" %>

      <% else %>

        <%= link_to "ログイン",
                    new_user_session_path,
                    class: "px-5 py-2 rounded-lg border border-primary text-primary" %>

        <%= link_to "新規登録",
                    new_user_registration_path,
                    class: "px-5 py-2 rounded-lg bg-primary text-on-primary" %>

      <% end %>

    </div>

  </nav>
</header>

    <% if notice.present? %>
      <div class="max-w-[1024px] mx-auto mt-4 px-gutter">
        <div class="rounded-lg bg-green-100 text-green-700 px-4 py-3">
          <%= notice %>
        </div>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="max-w-[1024px] mx-auto mt-4 px-gutter">
        <div class="rounded-lg bg-red-100 text-red-700 px-4 py-3">
          <%= alert %>
        </div>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>
  </body>
</html>